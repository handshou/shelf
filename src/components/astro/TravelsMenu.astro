---
import '@styles/globals.css'

const { assets } = Astro.props

type AssetType = {
	data: {
		public_id: string
		folder: string
		width: number
		last_updated: string
	}
}

const imgExists = (img: AssetType) => img.data.last_updated

// Shuffle assets
const shuffledAssets = assets
	.map((value: AssetType) => ({ value, sort: Math.random() }))
	.sort(
		(a: { value: AssetType; sort: number }, b: { value: AssetType; sort: number }) =>
			a.sort - b.sort
	)
	.map(({ value }) => value)

// Replaces astro-cloudinary's CldImage: c_fill 4:5 crop, auto format/quality
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME
const cldUrl = (publicId: string, width: number) =>
	`https://res.cloudinary.com/${cloudName}/image/upload/c_fill,w_${width},h_${Math.round(width * 1.25)},g_center/f_auto/q_auto/v1/${publicId}`
const srcsetWidths = [640, 828, 1080, 1280, 1668]
const cldSrcset = (publicId: string) =>
	srcsetWidths.map((w) => `${cldUrl(publicId, w)} ${w}w`).join(', ')
---

<html>
  <body>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {
        shuffledAssets.map((asset: AssetType) => (
          <div class="relative ease-out duration-300 hover:-translate-y-1">
            <a href={asset.data.folder}>
              <div class="opacity-80 font-sans text-xs text-neutral-200 text-left drop-shadow-md left-2 bottom-2 absolute pr-1">
                {asset.data.folder.split("/")[1]}
              </div>
              <img
                class="h-auto w-full object-cover rounded-lg"
                alt={asset.data.public_id}
                src={cldUrl(asset.data.public_id, 1080)}
                srcset={cldSrcset(asset.data.public_id)}
                sizes="(max-width: 640px) 40vw, 30vw"
                width={Math.round(asset.data.width * 0.4)}
                height={Math.round(asset.data.width * 0.5)}
                loading="lazy"
                decoding="async"
              />
            </a>
          </div>
        ))
      }
    </div>
  </body>
</html>
